# Build, log, and waveform outputs
build/*
logs/*
wave/*
*/build/*
*/logs/*
*/wave/*

# Keep directory placeholders
!.gitkeep
*/!.gitkeep
*/*/!.gitkeep

# Common simulator outputs
*.vcd
*.fst
*.fsdb
*.wlf
*.log

# Local Python tool cache
__pycache__/
*.pyc

# Local LLVM source/build/install payloads are large third-party artifacts.
llvm_s1/toolchain/llvm-project/
llvm_s1/toolchain/install/*
!llvm_s1/toolchain/install/.gitkeep

# Local OS/editor noise
.DS_Store
*.swp
*.swo

# KiCad per-user state and automatic recovery history
*.kicad_prl
**/.history/
*.kicad_sch-bak
*.kicad_pcb-bak
